{
  "name": "quick-note",
  "version": "1.0.0",
  "description": "Quick Note - 快速記錄到 Notion 的桌面小工具",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac"
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.quicknote.app",
    "productName": "Quick Note",
    "win": {
      "target": "nsis",
      "icon": "assets/tray-icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/tray-icon.icns"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**",
      "assets/**"
    ]
  }
}
